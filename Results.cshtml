@model ExtractedImageViewModel
@{
    ViewData["Title"] = "Extracted Images";
    ViewData["Breadcrumb"] = "Results";
}

<div class="d-flex flex-wrap align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold mb-1">
            <i class="bi bi-images me-2 text-primary"></i>Extracted Images
        </h2>
        <p class="text-muted mb-0">
            <strong>@Model.Images.Count</strong> image(s) extracted from
            <strong>@Model.TotalPages</strong> page(s) of
            <span class="badge bg-secondary">@(Model.OriginalFileName).pdf</span>
        </p>
    </div>
    <div class="d-flex gap-2 mt-2 mt-md-0">
        <a asp-action="DownloadAll" asp-route-sessionId="@Model.SessionId"
           asp-route-originalName="@Model.OriginalFileName"
           class="btn btn-success fw-semibold">
            <i class="bi bi-download me-1"></i>Download All (.zip)
        </a>
        <a asp-action="Index" class="btn btn-outline-primary fw-semibold">
            <i class="bi bi-arrow-repeat me-1"></i>Upload Another
        </a>
    </div>
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2 d-flex flex-wrap align-items-center gap-3">
        <span class="text-muted small"><i class="bi bi-funnel me-1"></i>Filter by page:</span>
        <select id="pageFilter" class="form-select form-select-sm" style="width:auto;">
            <option value="all">All Pages</option>
            @foreach (var p in Model.Images.Select(i => i.PageNumber).Distinct().OrderBy(x => x))
            {
                <option value="@p">Page @p</option>
            }
        </select>
        <span class="ms-auto text-muted small" id="visibleCount">Showing @Model.Images.Count of @Model.Images.Count</span>
    </div>
</div>

<!-- Image grid -->
<div class="row g-4" id="imageGrid">
    @foreach (var img in Model.Images)
    {
        <div class="col-sm-6 col-md-4 col-lg-3 img-card" data-page="@img.PageNumber">
            <div class="card h-100 border-0 shadow-sm overflow-hidden">
                <div class="position-relative" style="height: 220px; background: #f8fafc;">
                    <img src="@Url.Action("Image", "Pdf", new { sessionId = Model.SessionId, fileName = img.FileName })"
                         alt="Image @img.Index"
                         class="w-100 h-100"
                         style="object-fit: contain; cursor: zoom-in;"
                         data-bs-toggle="modal" data-bs-target="#previewModal"
                         onclick="showPreview('@Url.Action("Image", "Pdf", new { sessionId = Model.SessionId, fileName = img.FileName })', 'Image @img.Index', '@img.ContentType')" />
                    <span class="badge bg-dark bg-opacity-75 position-absolute top-0 end-0 m-2">
                        Page @img.PageNumber
                    </span>
                </div>
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-0 fw-semibold text-truncate" style="max-width:140px;"
                                title="@img.FileName">@img.FileName</h6>
                            <small class="text-muted">
                                @(img.FileSizeBytes < 1024
                                    ? img.FileSizeBytes + " B"
                                    : img.FileSizeBytes < 1048576
                                        ? (img.FileSizeBytes / 1024.0).ToString("F1") + " KB"
                                        : (img.FileSizeBytes / 1048576.0).ToString("F2") + " MB")
                            </small>
                        </div>
                        <a asp-action="Download"
                           asp-route-sessionId="@Model.SessionId"
                           asp-route-fileName="@img.FileName"
                           class="btn btn-sm btn-outline-primary"
                           title="Download">
                            <i class="bi bi-download"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Preview Modal -->
<div class="modal fade" id="previewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="previewTitle">Image Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-2" style="max-height:80vh; overflow:auto;">
                <img id="previewImg" src="" alt="Preview" class="img-fluid" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showPreview(src, title, type) {
        document.getElementById('previewImg').src = src;
        document.getElementById('previewTitle').textContent = title + ' (' + type + ')';
    }

    // Page filter
    document.getElementById('pageFilter').addEventListener('change', function () {
        const val = this.value;
        let shown = 0;
        document.querySelectorAll('.img-card').forEach(card => {
            const match = val === 'all' || card.dataset.page === val;
            card.style.display = match ? '' : 'none';
            if (match) shown++;
        });
        document.getElementById('visibleCount').textContent =
            'Showing ' + shown + ' of @Model.Images.Count';
    });
</script>
}
